@inject IConfiguration Configuration

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script>
        window.appConfig = window.appConfig || {};
        window.appConfig.baseUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Context.Request.PathBase.Value ?? string.Empty));
    </script>
    <title>@Configuration["App:SystemName"]</title>
    <style>
        .app-main { position: relative; min-height: 4rem; }
    </style>
    <script type="importmap"></script>
    @await RenderSectionAsync("Styles", required: false)

</head>
<body>
    @* jQuery must load once before UIFoundation loader (defer) so DataTables plugins stay on the same instance. *@
    <script src="@Url.Content("~/lib/jquery/jquery.min.js")" asp-append-version="true"></script>
    <div class="app-container">
        @await Html.PartialAsync("_Sidebar")
        <div class="app-right">
            @await Html.PartialAsync("_Topbar")

            <main role="main" class="app-main" id="app-main">
                @RenderBody()
            </main>

            <footer class="app-footer border-top text-muted">
                <div class="px-3 py-2">
                    &copy; 2026 - @Configuration["App:SystemName"]
                </div>
            </footer>
        </div>
    </div>

    <script src="http://10.230.8.170/uifoundation2/vendor/loader.js"
            data-ui-base="http://10.230.8.170/uifoundation2"
            defer></script>
    <script src="@Url.Content("~/js/loading.js")" asp-append-version="true" defer></script>
    <script src="@Url.Content("~/js/main-nav.js")" asp-append-version="true" defer></script>

    @await RenderSectionAsync("Scripts", required: false)
    @* @await Html.PartialAsync("_FloatingChat") *@
</body>
</html>
