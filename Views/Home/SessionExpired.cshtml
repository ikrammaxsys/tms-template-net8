@using System.Text.Json
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Session expired";
    Layout = null;
    var vaspBaseUrl = Configuration["Vasp:BaseUrl"]?.Trim();
    if (string.IsNullOrEmpty(vaspBaseUrl))
        vaspBaseUrl = "/";
    var vaspLabel = vaspBaseUrl.TrimEnd('/');
    if (string.IsNullOrEmpty(vaspLabel)) vaspLabel = "/";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="@Url.Content("~/Content/bootstrap.min.css")" />
</head>
<body>
    <div id="session-expired-root" class="d-flex flex-column align-items-center justify-content-center min-vh-100 bg-light px-3">
        <div class="card shadow-sm border-0" style="max-width: 440px; width: 100%;">
            <div class="card-body p-4 p-md-5 text-center">
                <div class="mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" fill="#dc3545" class="bi bi-x-circle-fill" viewBox="0 0 16 16" aria-hidden="true">
                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-4.146-3.146a.5.5 0 0 0-.708-.708L8 7.293 4.854 4.146a.5.5 0 1 0-.708.708L7.293 8l-3.147 3.146a.5.5 0 0 0 .708.708L8 8.707l3.146 3.147a.5.5 0 0 0 .708-.708L8.707 8l3.147-3.146z"/>
                    </svg>
                </div>
                <h1 class="h4 mb-3">Session expired</h1>
                <div class="alert alert-danger mb-3" role="alert">
                    Your session has expired or your authentication token is no longer valid.
                </div>
                <p class="text-muted small mb-0">
                    Redirecting to
                    <a href="@vaspBaseUrl">@vaspLabel</a>
                    in 3 seconds…
                </p>
            </div>
        </div>
    </div>
    <script>
        (function () {
            var target = @Html.Raw(JsonSerializer.Serialize(vaspBaseUrl));
            setTimeout(function () {
                window.location.href = target;
            }, 3000);
        })();
    </script>
</body>
</html>
