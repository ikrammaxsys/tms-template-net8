@{
    ViewData["Title"] = "Access denied";
    Layout = null;
    var name = (string?)ViewBag.AccessName;
    var right = (string?)ViewBag.AccessRight;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="@Url.Content("~/lib/bootstrap/dist/css/bootstrap.css")" />
</head>
<body>
    <div class="d-flex flex-column align-items-center justify-content-center min-vh-100 bg-light px-3">
        <div class="card shadow-sm border-0" style="max-width: 480px; width: 100%;">
            <div class="card-body p-4 p-md-5 text-center">
                <div class="mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" fill="#dc3545"
                         class="bi bi-shield-lock-fill" viewBox="0 0 16 16" aria-hidden="true">
                        <path d="M8 0c-.69 0-1.843.265-2.928.56-1.11.3-2.229.655-2.887.87a1.54 1.54 0 0 0-1.044 1.262c-.596 4.477.787 7.795 2.465 9.99a11.78 11.78 0 0 0 2.517 2.453c.386.273.744.482 1.048.625.28.132.581.24.829.24s.548-.108.829-.24a7 7 0 0 0 1.048-.625 11.78 11.78 0 0 0 2.517-2.453c1.678-2.195 3.061-5.513 2.465-9.99a1.54 1.54 0 0 0-1.044-1.263 63 63 0 0 0-2.887-.87C9.843.266 8.69 0 8 0m0 5a1.5 1.5 0 0 1 .5 2.915l.385 1.99a.5.5 0 0 1-.491.595h-.788a.5.5 0 0 1-.49-.595l.384-1.99A1.5 1.5 0 0 1 8 5"/>
                    </svg>
                </div>
                <h1 class="h4 mb-2">Access denied</h1>
                <p class="text-muted mb-3">
                    You don't have permission to view this page.
                </p>
                @if (!string.IsNullOrWhiteSpace(name))
                {
                    <div class="alert alert-warning text-start small mb-3" role="alert">
                        <div><strong>Resource:</strong> @name</div>
                        @if (!string.IsNullOrWhiteSpace(right))
                        {
                            <div><strong>Required right:</strong> @right</div>
                        }
                    </div>
                }
                <div class="d-flex gap-2 justify-content-center">
                    <a class="btn" style="background-color: #004b9b; color: white;" href="@Url.Content("~/Home/Index")">Go to home</a>
                    <a class="btn btn-outline-secondary" href="@Url.Action("LogoutPage", "ACLChecking")">Sign out</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
