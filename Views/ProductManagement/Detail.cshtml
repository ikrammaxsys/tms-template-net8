@{
    var id = ViewBag.Id as int? ?? 0;
    ViewData["Title"] = "Product Detail";
}

<div class="row g-0 px-3 tr-listing-header">
    <div class="col-sm-6 align-self-center">
        <p class="text-muted m-0 tr-listing-header-title">Product Detail</p>
    </div>
    <div class="col-sm-6 text-end align-self-center">
        <div class="d-flex justify-content-end">
            <div id="customDTButton"></div>
        </div>
    </div>
</div>
<div style="border-top:1px solid #F0F0F0; margin-top:-1px" class="tr-btm-line"></div>

<div class="page-container px-3 overflow-auto">
    <div class="tr-btm-btn-margin">
        <div id="detailLoading" class="text-center py-5 text-muted">Loading...</div>
        <div id="detailContent" style="display: none;">
            <div class="card mt-3 mb-2 card-height height-override">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div>
                            <h6 class="card-title text-muted m-0 p-0">Product Details</h6>
                        </div>
                        <div class="d-flex flex-wrap gap-2 align-items-center">
                            <a id="btnEdit" href="#" class="btn btn-sm btn-primary">Edit</a>
                        </div>
                    </div>

                    <hr />
                    <div class="row mt-2 align-items-baseline">
                        <div class="col-sm-2">
                            <p class="text-muted">Product Name <span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <p class="m-0" id="detailName">-</p>
                        </div>
                    </div>
                    <div class="row mt-2 align-items-baseline">
                        <div class="col-sm-2">
                            <p class="text-muted">SKU <span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <p class="m-0" id="detailSku">-</p>
                        </div>
                    </div>
                    <div class="row mt-2 align-items-baseline">
                        <div class="col-sm-2">
                            <p class="text-muted">Price <span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <p class="m-0" id="detailPrice">-</p>
                        </div>
                    </div>
                    <div class="row mt-2 align-items-baseline">
                        <div class="col-sm-2">
                            <p class="text-muted">Status <span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <p class="m-0" id="detailStatus">-</p>
                        </div>
                    </div>
                    <div class="row mt-2 align-items-baseline">
                        <div class="col-sm-2">
                            <p class="text-muted">Description <span style="float:right">:</span></p>
                        </div>
                        <div class="col-sm-4">
                            <p class="m-0" id="detailDescription">-</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row row-cols-auto justify-content-between g-1 tr-btm-btn-area tr-btm-size" style="padding-right: 20px;">
                <div><button id="btnDelete" type="button" class="btn btn-sm btn-danger mx-1" data-bs-toggle="modal" data-bs-target="#confirmation-modal">Delete</button></div>
                <div class="col"><button id="btnBack" type="button" class="btn btn-sm btn-secondary mx-1">Back</button></div>
            </div>
        </div>
        <div id="detailError" class="text-center py-5 text-danger" style="display: none;">Failed to load product.</div>
    </div>
</div>

@await Html.PartialAsync("~/Views/Shared/_ConfirmationModal.cshtml", new tms_template_net8.ViewModels.ConfirmationModalViewModel { ModalId = "confirmation-modal", Message = "Are you sure to delete this product?", ConfirmButtonId = "btnConfirmDelete", UseSmallButtons = false })

@section Scripts {
    <script type="text/javascript">
        window.productManagementDetailConfig = {
            productId: @id,
            urls: {
                index: '@Url.Action("Index", "ProductManagement")',
                edit: '@Url.Action("Edit", "ProductManagement", new { id = id })',
            }
        };
    </script>
    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="~/js/apiClient.js" asp-append-version="true"></script>
    <script type="module" src="~/ProductManagement/js/detail.js" asp-append-version="true"></script>
}
